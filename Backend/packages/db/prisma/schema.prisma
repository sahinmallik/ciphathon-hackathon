// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        String            @id @default(uuid())
  clerkId   String            @unique
  email     String            @unique
  name      String?
  createdAt DateTime          @default(now())

  domains   Domain[]
}

model Domain {
  id          String   @id @default(uuid())
  domainName  String   @unique
  secretKey   String   @unique
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  verifiedAt  DateTime?
  expiresAt   DateTime?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ssl         DomainSSL?
  emailSecurity DomainEmailSecurity?   // ✅ ADD THIS


  @@index([domainName])
}

model DomainSSL {
  id             String   @id @default(uuid())
  valid          String
  daysRemaining  Int
  issuer         String
  protocol       String
  lastCheckedAt  DateTime @default(now())

  domainId       String   @unique
  domain         Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}


model DomainEmailSecurity {
  id            String   @id @default(uuid())

  domain        String

  // SPF
  spfExists     Boolean
  spfRecord     String?

  // DMARC
  dmarcExists   Boolean
  dmarcRecord   String?

  // DKIM
  dkimExists    String   // "true" | "false" | "likely"
  dkimRecord    String?
  dkimSelector  String?
  dkimNote      String?

  scannedAt     DateTime @default(now())

  domainId      String   @unique
  domainRef     Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}